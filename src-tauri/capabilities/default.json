{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for MySerial main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "fs:default",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "**" }]
    },
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "store:default"
  ]
}
